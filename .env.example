# Server-only Vercel access token with permission to read Web Analytics.
VERCEL_ANALYTICS_TOKEN=

# Optional overrides. VERCEL_PROJECT_ID is normally supplied by Vercel when
# system environment variables are exposed to the deployment.
VERCEL_ANALYTICS_PROJECT_ID=

# Required only when the project belongs to a Vercel team. Personal projects
# omit this value.
VERCEL_ANALYTICS_TEAM_ID=
